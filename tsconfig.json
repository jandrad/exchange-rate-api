{
    "compilerOptions": {
        "target": "esnext",
        "lib": ["esnext"],
        "module": "esnext",
        "moduleResolution": "Node",
        "types": ["@cloudflare/workers-types"],
        "outDir": "./build",
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "strict": true,
        "skipLibCheck": true
    }
}
